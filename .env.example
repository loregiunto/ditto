NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable-your_key
DATABASE_URL=postgresql://postgres.[your-project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Mapbox — US-001 (listing creation)
# Server token: scope GEOCODING:READ only. Get one at https://account.mapbox.com
MAPBOX_ACCESS_TOKEN=
# Public restricted token (URL-restricted to your domain) for client-side autocomplete
NEXT_PUBLIC_MAPBOX_TOKEN=

# E2E test credentials (optional, only needed to run `npm run test:e2e`)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=