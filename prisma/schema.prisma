generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  supabaseId      String   @unique
  email           String   @unique
  name            String?
  image           String?
  stripeAccountId String?
  identityStatus  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings        Listing[]

  @@map("users")
}

enum HostType {
  PRIVATE
  BUSINESS
}

enum ListingStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

model Listing {
  id               String         @id @default(uuid())
  hostId           String
  host             User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  title            String
  description      String
  hostType         HostType
  addressFull      String
  addressDisplay   String
  latitude         Float
  longitude        Float
  hourlyPriceCents Int
  status           ListingStatus  @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  photos             ListingPhoto[]
  availabilityRules  AvailabilityRule[]

  @@index([hostId])
  @@map("listings")
}

model AvailabilityRule {
  id          String   @id @default(uuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  createdAt   DateTime @default(now())

  @@index([listingId, dayOfWeek])
  @@map("availability_rules")
}

model ListingPhoto {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@map("listing_photos")
}
