generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  supabaseId      String   @unique
  email           String   @unique
  name            String?
  image           String?
  stripeAccountId String?
  identityStatus  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings        Listing[]
  bookings        Booking[]

  @@map("users")
}

enum HostType {
  PRIVATE
  BUSINESS
}

enum ListingStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum BookingMode {
  INSTANT
  REQUEST
}

model Listing {
  id               String         @id @default(uuid())
  hostId           String
  host             User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  title            String
  description      String
  hostType         HostType
  addressFull      String
  addressDisplay   String
  latitude         Float
  longitude        Float
  hourlyPriceCents Int
  bookingMode      BookingMode    @default(INSTANT)
  status           ListingStatus  @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  photos             ListingPhoto[]
  availabilityRules  AvailabilityRule[]
  bookings           Booking[]

  @@index([hostId])
  @@map("listings")
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  REFUNDED
}

model Booking {
  id                       String        @id @default(uuid())
  listingId                String
  listing                  Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId                   String
  user                     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startsAt                 DateTime
  endsAt                   DateTime
  amountCents              Int
  platformFeeCents         Int
  status                   BookingStatus @default(PENDING_PAYMENT)
  stripeCheckoutSessionId  String?       @unique
  stripePaymentIntentId    String?       @unique
  pendingExpiresAt         DateTime?
  confirmedAt              DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  @@index([listingId, startsAt, endsAt, status])
  @@index([userId])
  @@map("bookings")
}

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@map("stripe_events")
}

model AvailabilityRule {
  id          String   @id @default(uuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  createdAt   DateTime @default(now())

  @@index([listingId, dayOfWeek])
  @@map("availability_rules")
}

model ListingPhoto {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@map("listing_photos")
}
